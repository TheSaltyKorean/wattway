# Google Maps API key — required for map display, routing, and address search
# Enable these APIs in Google Cloud Console: Maps JavaScript API, Routes API, Places API (New)
# Project must be linked to an active billing account (per-SKU free tiers cover personal use)
# https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Open Charge Map API key — REQUIRED (anonymous access was discontinued)
# Free signup: https://openchargemap.org/site/develop/api
NEXT_PUBLIC_OCM_API_KEY=

# Google Analytics 4 measurement id (G-XXXXXXXX) — OPTIONAL
# Leave blank to disable analytics entirely. In the Pages deploy this comes from
# the GA_ID Actions secret. Create a property at https://analytics.google.com/
NEXT_PUBLIC_GA_ID=
