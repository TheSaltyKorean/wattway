# Google Maps API key — required for map display, routing, and address search
# Enable these APIs in Google Cloud Console: Maps JavaScript API, Directions API, Places API
# Free tier: $200/month credit covers substantial usage
# https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Open Charge Map API key — optional, increases rate limits
# https://openchargemap.org/site/develop/api
NEXT_PUBLIC_OCM_API_KEY=
